---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logoImage from '../assets/images/logo.png';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "başıbozuk e-yayıncılık. Karadelikten yayınlar." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="tr">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-68YL8G0X51" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-68YL8G0X51');
    </script>
    
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description || "başıbozuk e-yayıncılık. Karadelikten yayınlar."} />
    
    <!-- SEO & Canonical -->
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Font Preload -->
    <link rel="preload" href="/fonts/merriweather-10.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/merriweather-9.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/merriweather-15.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/merriweather-14.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="site-logo-container">
          <Image src={logoImage} format="webp" width={80} loading="eager" alt="başıbozuk e-yayıncılık Logo" class="header-logo" /> 
          <span class="site-title-lowercase">başıbozuk e-yayıncılık</span>
        </a>
        
        <div class="header-social">
          <a href="https://oguzkarayemis.academia.edu/" target="_blank" rel="noopener noreferrer" aria-label="Academia.edu">
            <span style="font-weight: bold; color: var(--color-bg);">Academia.edu</span>
          </a>
        </div>

        <nav>
          <a href="/manifesto/">Manifesto</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>başıbozuk e-yayıncılık &copy; {new Date().getFullYear()}. Karadelikten yayınlar.</p>
        <div class="footer-contact" style="margin-bottom: 0.5rem;">İletişim: <a href="mailto:oguz.karayemis@basibozukyayincilik.org">oguz.karayemis@basibozukyayincilik.org</a></div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    background-color: var(--color-text);
    color: var(--color-bg);
    padding: 1.5rem 0;
  }
  .site-header .container {
    padding: 0 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .site-header a {
    color: var(--color-bg);
    text-decoration: none;
  }
  .site-header a:hover {
    color: var(--color-accent);
  }
  .site-logo-container {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-text);
  }
  .header-logo {
    height: 40px;
    width: auto;
  }
  .site-title-lowercase {
    font-size: 1.5rem;
    letter-spacing: 1px;
    font-weight: 700;
  }
  nav {
    display: flex;
    gap: 1.5rem;
    font-weight: 700;
  }
  .header-social {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin: 0 auto 0 2rem; /* site ismi ile menü arasına yerleşmesi için */
  }
  .header-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    opacity: 0.9;
  }
  .header-social a:hover {
    opacity: 1;
    transform: translateY(-2px);
  }
  .header-social svg {
    width: 22px;
    height: 22px;
    fill: var(--color-bg);
    transition: fill 0.2s ease;
  }
  .header-social a:hover svg {
    fill: var(--color-accent);
  }
  .site-footer {
    border-top: 1px solid var(--color-bg-secondary);
    margin-top: 4rem;
    padding: 2rem 0;
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 600px) {
    .site-header .container {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
    nav {
      justify-content: center;
      width: 100%;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .header-social {
      margin: 0.5rem auto 0 auto;
      justify-content: center;
      width: 100%;
    }
    .site-footer {
      border-top: 1px solid var(--color-bg-secondary);
      margin-top: 4rem;
      padding: 2rem 0;
      text-align: center;
      font-size: 0.9rem;
      color: var(--color-text-muted);
    }
  }
</style>
