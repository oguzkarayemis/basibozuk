---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sayfa Bulunamadı | başıbozuk e-yayıncılık">
  <div class="not-found">
    <h1>404</h1>
    <p>Hayda! Ya karadeliğe böyle bir sayfa hiç girmemiş ya da şu an kütleçekimi yüzünden çıkamıyor!</p>
    <a href="/" class="home-link">Ana Sayfaya Dön</a>
  </div>
</Layout>

<style>
  .not-found {
    text-align: center;
    margin-top: 4rem;
    padding: 2rem;
    min-height: 50vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }
  .not-found h1 {
    font-size: 6rem;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }
  .not-found p {
    font-size: 1.5rem;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }
  .home-link {
    display: inline-block;
    background-color: var(--color-text);
    color: var(--color-bg);
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    font-weight: 700;
    border-radius: 4px;
    font-size: 1.1rem;
    transition: background-color 0.3s ease;
  }
  .home-link:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }
</style>
